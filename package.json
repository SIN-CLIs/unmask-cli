{
  "name": "unmask-cli",
  "version": "0.1.0",
  "description": "X-ray vision for web automation agents: CDP network sniffing, semantic DOM analysis, console listening, self-healing selectors and sequential queue processing.",
  "license": "MIT",
  "author": "SIN-CLIs",
  "type": "module",
  "bin": {
    "unmask": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "scripts/postinstall.mjs",
    "integrations",
    "README.md",
    "HACKING.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run tests/e2e.test.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "doctor": "node dist/cli.js doctor",
    "postinstall": "node scripts/postinstall.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.64",
    "ai": "^6.0.168",
    "archiver": "^7.0.1",
    "commander": "^14.0.3",
    "playwright": "^1.48.0",
    "ws": "^8.20.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.4",
    "@types/node": "^22.7.5",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^10.2.1",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^6.0.3",
    "vitest": "^2.1.2"
  },
  "keywords": [
    "cli",
    "playwright",
    "web-automation",
    "scraping",
    "cdp",
    "chrome-devtools-protocol",
    "agent",
    "stealth",
    "self-healing",
    "zod"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SIN-CLIs/unmask-cli.git"
  },
  "homepage": "https://github.com/SIN-CLIs/unmask-cli#readme",
  "bugs": {
    "url": "https://github.com/SIN-CLIs/unmask-cli/issues"
  }
}
